{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3-instruct-16k",
  "enabled_providers": ["ollama"],
  "autoupdate": false,
  "share": "disabled",
  "tools": {
    "*": false,
    "compliance-assistant_*": true
  },
  "permission": {
    "*": "deny",
    "compliance-assistant_*": "allow"
  },
  "agent": {
    "build": {
      "temperature": 0.1,
      "steps": 4
    }
  },
  "mcp": {
    "compliance-assistant": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        "mcp_server.py"
      ],
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3-instruct-16k": {
          "name": "Qwen3 4B Instruct 16k ctx (local)"
        }
      }
    }
  }
}
